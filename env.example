# Clerk Authentication
CLERK_SECRET_KEY=sk_test_1234567890123456789012345678901234567890123456789012345678901234
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_1234567890123456789012345678901234567890123456789012345678901234
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Database
DATABASE_URL=postgresql://testuser:testpass@localhost:5432/testdb

# Auth Configuration
NEXTAUTH_SECRET=test-secret-for-ci-cd-only-not-production-safe
NEXTAUTH_URL=http://localhost:3000

# Upload Thing
UPLOADTHING_SECRET=sk_live_test123456789012345678901234567890123456789012345678901234567890
UPLOADTHING_APP_ID=testapp123
UPLOADTHING_TOKEN=test_token_123456789012345678901234567890

# Platform Configuration
NEXT_PUBLIC_DOMAIN=localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_SCHEME=http
NEXT_PUBLIC_PLATFORM_AGENY_PERCENT=10
NEXT_PUBLIC_PLATFORM_ONETIME_FEE=99
NEXT_PUBLIC_PLATFORM_SUBSCRIPTION_PERCENT=5
NEXT_WEBRLY_PRODUCT_ID=prod_test123456789

# Environment
NODE_ENV=test
CI=true 

# === MONITORING & LOGGING ===
# Version de l'application (sera injectée automatiquement par CI/CD)
NEXT_PUBLIC_APP_VERSION=1.0.0

# === ALERTES CRITIQUES (Optionnel) ===
# Webhook Slack pour alertes critiques - laissez vide si pas configuré
# WEBHOOK_CRITICAL_ALERTS=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# Webhook Discord alternatif
# WEBHOOK_CRITICAL_ALERTS=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# === TRACKING D'ERREURS (Phase 2 - Optionnel) ===
# Sentry gratuit jusqu'à 5K erreurs/mois - https://sentry.io
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# === MONITORING EXTERNE (Phase 3 - Optionnel) ===
# DataDog, New Relic, Grafana Cloud, etc.
# MONITORING_API_KEY=
# MONITORING_ENDPOINT=

# === CONFIGURATION LOCALE ===
# Pour tester les alertes en développement
# WEBHOOK_TEST_MODE=true
# LOG_LEVEL=debug