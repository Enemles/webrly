NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/agency/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/agency/register
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
DB_USERNAME=
DB_PASSWORD=

NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=localhost:3000
NEXT_PUBLIC_SCHEME=http://

UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=
UPLOADTHING_TOKEN=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_LIVE=
NEXT_PUBLIC_STRIPE_CLIENT_ID=
NEXT_PUBLIC_PLATFORM_SUBSCRIPTION_PERCENT=1
NEXT_PUBLIC_PLATFORM_ONETIME_FEE=2
NEXT_PUBLIC_PLATFORM_AGENY_PERCENT=1
NEXT_WEBRLY_PRODUCT_ID=

# Configuration Docker locale
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=weberly

# URLs de connexion
# En local, utilisez cette URL de connexion (Docker)
DATABASE_URL=postgresql://root:password@localhost:5432/weberly

# URL de production (à remplir)
PROD_DATABASE_URL=

# Pour la connexion sans pgbouncer
DATABASE_URL_UNPOOLED=

# Autres variables Postgres
PGHOST=
PGHOST_UNPOOLED=
POSTGRES_BACKUP_PASSWORD=

# Builder.io API Key
NEXT_PUBLIC_BUILDER_API_KEY=

# Prometheus scraper bearer token. Generate: openssl rand -base64 32
# Required in production — /api/metrics returns 503 if missing
METRICS_TOKEN= 