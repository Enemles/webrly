{
  "name": "webrly",
  "version": "2.15.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "prisma generate && next dev",
    "generate": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "docker:start": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:setup:local": "npm run docker:start && npm run db:push",
    "db:seed": "npx -y tsx prisma/seed.ts",
    "db:export": "node export-data.js",
    "db:import": "node import-data.js",
    "db:duplicate": "npm run db:export && npm run db:import",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:basic": "playwright test tests/homepage.spec.ts --debug",
    "test:simple": "playwright test tests/simple.spec.ts",
    "test:site": "playwright test tests/site.spec.ts"
  },
